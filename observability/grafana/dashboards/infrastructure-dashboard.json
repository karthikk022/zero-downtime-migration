{
  "title": "Infrastructure Dashboard",
  "version": 1,
  "panels": [
    {
      "title": "Node CPU Usage",
      "type": "graph",
      "targets": [
        {
          "expr": "1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) by (instance)",
          "legendFormat": "{{ instance }}"
        }
      ],
      "yaxes": [{ "format": "percentunit" }]
    },
    {
      "title": "Node Memory Usage",
      "type": "gauge",
      "targets": [
        {
          "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100",
          "legendFormat": "Memory %"
        }
      ]
    },
    {
      "title": "Node Disk Usage",
      "type": "graph",
      "targets": [
        {
          "expr": "100 - (node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"} * 100)",
          "legendFormat": "{{ instance }}"
        }
      ]
    },
    {
      "title": "Network I/O",
      "type": "graph",
      "targets": [
        {
          "expr": "sum(rate(node_network_receive_bytes_total[5m])) by (instance)",
          "legendFormat": "In: {{ instance }}"
        },
        {
          "expr": "sum(rate(node_network_transmit_bytes_total[5m])) by (instance)",
          "legendFormat": "Out: {{ instance }}"
        }
      ]
    },
    {
      "title": "EKS Node Count",
      "type": "stat",
      "targets": [
        {
          "expr": "count(kube_node_status_condition{condition=\"Ready\", status=\"true\"})",
          "legendFormat": "Ready Nodes"
        }
      ]
    },
    {
      "title": "Pod Count by Namespace",
      "type": "piechart",
      "targets": [
        {
          "expr": "count(kube_pod_status_phase{phase=\"Running\"}) by (namespace)",
          "legendFormat": "{{ namespace }}"
        }
      ]
    },
    {
      "title": "Cluster Autoscaler Activity",
      "type": "graph",
      "targets": [
        {
          "expr": "cluster_autoscaler_scaled_up_count_total",
          "legendFormat": "Scale Up"
        },
        {
          "expr": "cluster_autoscaler_scaled_down_count_total",
          "legendFormat": "Scale Down"
        }
      ]
    }
  ],
  "time": { "from": "now-24h", "to": "now" }
}
